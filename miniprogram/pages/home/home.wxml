<view class="page">
  <view class="hero card">
    <text class="eyebrow">Travel Guide</text>
    <text class="title">出行攻略</text>
    <text class="muted">每次出行一份 Excel · 同步到小程序 · 历史行程可回看</text>
  </view>

  <view class="section-title">选择行程</view>
  <block wx:for="{{trips}}" wx:key="id">
    <view class="trip-card card" bindtap="openTrip" data-id="{{item.id}}">
      <view class="trip-head">
        <text class="trip-title">{{item.title}}</text>
        <text wx:if="{{item.id === activeId}}" class="tag active-tag">编辑中</text>
        <text wx:if="{{item.id === currentId}}" class="tag curr-tag">当前</text>
      </view>
      <text class="muted">{{item.subtitle}}</text>
      <text class="muted">{{item.dateStart}} — {{item.dateEnd}}</text>
      <text class="muted tiny">更新 {{item.updatedAt}}</text>
    </view>
  </block>

  <button class="btn-primary" bindtap="goFlow">进入当前行程</button>
  <view class="hint muted">在电脑运行「同步行程到网页」会同时更新小程序数据</view>
</view>
