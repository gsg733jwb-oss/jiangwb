.page { padding: 24rpx; padding-bottom: 48rpx; }
.hero { margin-bottom: 28rpx; }
.eyebrow { display: block; color: #4d9fff; font-size: 22rpx; margin-bottom: 8rpx; }
.title { display: block; font-size: 44rpx; font-weight: 700; margin-bottom: 12rpx; }
.section-title { font-size: 30rpx; font-weight: 700; margin: 16rpx 0 20rpx; }
.trip-card { }
.trip-head { display: flex; flex-wrap: wrap; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.trip-title { font-size: 32rpx; font-weight: 700; flex: 1; }
.active-tag { background: rgba(52,211,153,.2); color: #34d399; }
.curr-tag { background: rgba(77,159,255,.2); color: #4d9fff; }
.tiny { display: block; margin-top: 8rpx; font-size: 22rpx; }
.btn-primary { margin-top: 28rpx; }
.hint { margin-top: 24rpx; text-align: center; font-size: 22rpx; }
